.vscode
.idea
.opencode
.sisyphus
.yamllint

# Ignore changes to sample environments
helmfile/environments/dev/*.yaml.gotmpl
helmfile/environments/test/*.yaml.gotmpl
helmfile/environments/prod/*.yaml.gotmpl
helmfile/environments/dev/*.yaml
helmfile/environments/test/*.yaml
helmfile/environments/prod/*.yaml
helmfile/environments/dev/*.json
helmfile/environments/test/*.json
helmfile/environments/prod/*.json
helmfile/environments/dev/*/
helmfile/environments/test/*/
helmfile/environments/prod/*/
!helmfile/environments/dev/sample.yaml.gotmpl
!helmfile/environments/test/sample.yaml.gotmpl
!helmfile/environments/prod/sample.yaml.gotmpl

# Ignore in CI generated files
.kyverno/opendesk.yaml
.kyverno/kyverno-test.yaml

# Ignore editor/OS files
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# Windows artifacts
nul

# Ignore ./log directory and *.log files
logs
*.log

# Ignore backup files, e.g. created by the script that eases the local chart development
*.bak

# Ignore helmfile build artifacts
helmfile-child.yaml-*/
*.tgz

# Ignore Python virtual environments
.venv/
venv/
__pycache__/
__pycache__
*.py[cod]
*$py.class

# Node.js
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# npm
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Python test/coverage artifacts
htmlcov/
.coverage
.coverage.*
.pytest_cache/
.ruff_cache/

# Generated Playwright specs (regenerated from YAML via generate-playwright-specs.py)
tests/playwright/ics-*.spec.js

# Playwright test artifacts
test-results/

# CE submodule (embedded repo, managed by CI/CD)
helmfile/ce/

# Ignore sensitive credential files
k8up-*.yaml
*secrets*.yaml
*credentials*.yaml
*.env
*.env.*
*.pem
*.key
*.crt
*.p12
!*secrets*.enc.yaml

# Allow test env templates to be committed
!*.env.test
