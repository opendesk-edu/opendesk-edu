{
  "title": "HRZ Deployment Health",
  "description": "Centralized monitoring for HRZ openDesk Edu deployment",
  "tags": ["hrz", "opendesk-edu", "production"],
  "timezone": "Europe/Berlin",
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "container",
        "type": "query",
        "datasource": "Loki",
        "query": "label_values(container)",
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "title": "HTTP Status Codes",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "sum by (status) (rate({job=\"traefik\"} | json | status=~\"[0-9]+\" [5m]))",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "title": "Error Rate by Container",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "sum by (container) (rate({job=\"docker\"} |~ \"(?i)(error|exception|failed)\" [5m]))",
          "legendFormat": "{{container}}"
        }
      ]
    },
    {
      "title": "Container Logs (Errors)",
      "type": "logs",
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "{container=~\"$container\"} |~ \"(?i)(error|exception|failed)\"",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Request Rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 18},
      "targets": [
        {
          "expr": "sum(rate({job=\"traefik\"} [5m]))",
          "legendFormat": "Requests/s"
        }
      ]
    },
    {
      "title": "Response Time (p95)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 18},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate({job=\"traefik\"} | json | duration_unix_seconds!=0 [5m])) by (le))",
          "legendFormat": "p95"
        }
      ]
    }
  ]
}
