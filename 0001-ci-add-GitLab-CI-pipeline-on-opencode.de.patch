From b721b5ad53d9a6229d387d4d5da8f7b2913ae297 Mon Sep 17 00:00:00 2001
From: =?UTF-8?q?Tobias=20Wei=C3=9F?= <weissto@hrz.uni-marburg.de>
Date: Mon, 29 Jun 2026 08:32:04 +0200
Subject: [PATCH] ci: add GitLab CI pipeline on opencode.de

---
 .gitlab-ci.yml | 33 +++++++++++++++++++++++++++++++++
 1 file changed, 33 insertions(+)
 create mode 100644 .gitlab-ci.yml

diff --git a/.gitlab-ci.yml b/.gitlab-ci.yml
new file mode 100644
index 00000000..6524859f
--- /dev/null
+++ b/.gitlab-ci.yml
@@ -0,0 +1,33 @@
+image: alpine:3.21
+
+stages:
+  - validate
+  - lint
+
+before_script:
+  - apk add --no-cache helm yq git
+
+validate-helmfile:
+  stage: validate
+  script:
+    - echo "Helmfile structure validation"
+    - test -f helmfile.yaml.gotmpl
+    - test -d helmfile/apps
+    - test -d helmfile/environments
+    - echo "✅ Basic structure validated"
+  rules:
+    - if: $CI_PIPELINE_SOURCE == "merge_request_event" || $CI_COMMIT_BRANCH == "main"
+
+lint-charts:
+  stage: lint
+  script:
+    - echo "Linting local charts..."
+    - for chart in helmfile/charts/*/; do
+        if [ -f "$chart/Chart.yaml" ]; then
+          echo "  Linting $chart..."
+          helm lint "$chart" || true
+        fi
+      done
+    - echo "✅ Chart linting completed"
+  rules:
+    - if: $CI_PIPELINE_SOURCE == "merge_request_event" || $CI_COMMIT_BRANCH == "main"
-- 
