---
releases:
  - name: "collab-dashboard"
    chart: "../../charts/collab-dashboard"
    wait: true
    values:
      - "values.yaml.gotmpl"
    installed: {{ .Values.apps.collabDashboard.enabled }}
    timeout: 300
commonLabels:
  deployStage: "060-frontend"
  component: "collab-dashboard"
