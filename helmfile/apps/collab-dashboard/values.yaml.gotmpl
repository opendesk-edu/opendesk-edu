---
ingress:
  enabled: true
  hosts:
    - "collab.{{ .Values.global.domain }}"
  annotations:
    kubernetes.io/ingress.class: haproxy
    haproxy-ingress.github.io/ssl-redirect: "true"
image:
  repository: opendesk-edu/collab-dashboard
  tag: "latest"
