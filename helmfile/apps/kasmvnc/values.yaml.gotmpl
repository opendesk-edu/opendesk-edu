---
ingress:
  enabled: true
  hosts:
    - "desktop.{{ .Values.global.domain }}"
  annotations:
    kubernetes.io/ingress.class: haproxy
    haproxy-ingress.github.io/ssl-redirect: "true"
persistence:
  enabled: true
  size: 10Gi
