---
image:
  repository: n8nio/n8n
  tag: latest

config:
  host: n8n.opendesk.hrz.uni-marburg.de
  encryptionKey: {{ .Values.apps.n8n.encryptionKey | default "" }}
  dbType: sqlite

resources:
  requests:
    cpu: 100m
    memory: 256Mi
  limits:
    cpu: 1000m
    memory: 1Gi

persistence:
  enabled: true
  size: 5Gi
  storageClass: {{ coalesce .Values.persistence.storages.n8n.storageClassName .Values.persistence.storageClassNames.RWO | quote }}
