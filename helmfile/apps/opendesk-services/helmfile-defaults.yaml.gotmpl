---
helmfiles:
  - path: "./helmfile-child.yaml.gotmpl"
    values:
      - "../../environments/default/*.yaml.gotmpl"
      {{- if eq (env "OPENDESK_ENTERPRISE") "true" }}
      - "../..//environments/default-enterprise-overrides/*.yaml.gotmpl"
      {{- end }}
      - {{ toYaml .Values | nindent 8 }}
...
