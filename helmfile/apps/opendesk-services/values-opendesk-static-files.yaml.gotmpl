---
global:
  domain: {{ .Values.global.domain | quote }}
  hosts:
    {{ .Values.global.hosts | toYaml | nindent 4 }}
  imagePullSecrets:
    {{ .Values.global.imagePullSecrets | toYaml | nindent 4 }}

additionalAnnotations:
  {{ .Values.annotations.opendeskServicesStaticFiles.additional | toYaml | nindent 2 }}

assets:
  # all keys must be lowercase
  adminbot:
    subdomain: {{ .Values.global.hosts.adminBot | quote }}
    pathType: "ImplementationSpecific"
    paths:
      - path: "/robots.txt"
        data: {{ .Values.theme.other.robotsTxt | quote }}
  collabora:
    subdomain: {{ .Values.global.hosts.collabora | quote }}
    pathType: "ImplementationSpecific"
    paths:
      - path: "/robots.txt"
        data: {{ .Values.theme.other.robotsTxt | quote }}
  cryptpad:
    subdomain: {{ .Values.global.hosts.cryptpad | quote }}
    pathType: "ImplementationSpecific"
    paths:
      - path: "/robots.txt"
        data: {{ .Values.theme.other.robotsTxt | quote }}
  element:
    subdomain: {{ .Values.global.hosts.element | quote }}
    pathType: "ImplementationSpecific"
    paths:
      - path: "/vector-icons/24.97ab000.png"
        data: {{ .Values.theme.imagery.chat.faviconPng | quote }}
      - path: "/vector-icons/120.570a7f9.png"
        data: {{ .Values.theme.imagery.chat.faviconPng | quote }}
      - path: "/vector-icons/144.5a63bf2.png"
        data: {{ .Values.theme.imagery.chat.faviconPng | quote }}
      - path: "/vector-icons/152.1ccdc8a.png"
        data: {{ .Values.theme.imagery.chat.faviconPng | quote }}
      - path: "/vector-icons/180.30b915f.png"
        data: {{ .Values.theme.imagery.chat.faviconPng | quote }}
      - path: "/vector-icons/512.7ce350d.png"
        data: {{ .Values.theme.imagery.chat.faviconPng | quote }}
      - path: "/robots.txt"
        data: {{ .Values.theme.other.robotsTxt | quote }}
  jitsi:
    subdomain: {{ .Values.global.hosts.jitsi | quote }}
    pathType: "ImplementationSpecific"
    paths:
      - path: "/images/favicon.svg"
        data: {{ .Values.theme.imagery.videoconference.faviconSvg | quote }}
      - path: "/robots.txt"
        data: {{ .Values.theme.other.robotsTxt | quote }}
  keycloak:
    subdomain: {{ .Values.global.hosts.keycloak | quote }}
    pathType: "ImplementationSpecific"
    paths:
      - path: "/opendesk-static-files/login/logo.svg"
        data: {{ .Values.theme.imagery.login.logoSvg | quote }}
      - path: "/robots.txt"
        data: {{ .Values.theme.other.robotsTxt | quote }}
  nextcloud:
    subdomain: {{ .Values.global.hosts.nextcloud | quote }}
    pathType: "ImplementationSpecific"
    paths:
      - path: "/core/img/favicon-touch.png"
        data: {{ .Values.theme.imagery.files.faviconPng | quote }}
      - path: "/core/img/favicon.ico"
        data: {{ .Values.theme.imagery.files.faviconIco | quote }}
      - path: "/apps/integration_swp/logo"
        data: {{ .Values.theme.imagery.logoHeaderSvgB64 | quote }}
        mimeType: "image/svg+xml"
      - path: "/apps/theming/img/background/jenna-kim-the-globe-dark.webp"
        data: {{ .Values.theme.imagery.login.backgroundJpg | quote }}
        mimeType: "image/jpeg"
      - path: "/robots.txt"
        data: {{ .Values.theme.other.robotsTxt | quote }}
  notes:
    subdomain: {{ .Values.global.hosts.notes | quote }}
    pathType: "ImplementationSpecific"
    paths:
      - path: "/assets/favicon-light.ico"
        data: {{ .Values.theme.imagery.notes.faviconIco | quote }}
      - path: "/assets/favicon-dark.png"
        data: {{ .Values.theme.imagery.notes.faviconPng | quote }}
      - path: "/assets/favicon-light.png"
        data: {{ .Values.theme.imagery.notes.faviconPng | quote }}
      - path: "/robots.txt"
        data: {{ .Values.theme.other.robotsTxt | quote }}
  openproject:
    subdomain: {{ .Values.global.hosts.openproject | quote }}
    pathType: "ImplementationSpecific"
    paths:
      - path: "/robots.txt"
        data: {{ .Values.theme.other.robotsTxt | quote }}
  openxchange:
    subdomain: {{ .Values.global.hosts.openxchange | quote }}
    pathType: "ImplementationSpecific"
    paths:
      - path: "/appsuite/favicon.ico"
        data: {{ .Values.theme.imagery.groupware.faviconIco | quote }}
      - path: "/appsuite/favicon.svg"
        data: {{ .Values.theme.imagery.groupware.faviconSvg | quote }}
      - path: "/robots.txt"
        data: {{ .Values.theme.other.robotsTxt | quote }}
  portal:
    subdomain: {{ .Values.global.hosts.nubus | quote }}
    pathType: "ImplementationSpecific"
    paths:
      - path: "/univention/portal/icons/logos/domain.svg"
        data: {{ .Values.theme.imagery.logoHeaderSvgB64 | quote }}
      - path: "/static-files/portal/background.svg"
        data: {{ .Values.theme.imagery.portal.backgroundSvg | quote }}
      - path: "/static-files/portal/waiting-spinner.svg"
        data: {{ .Values.theme.imagery.portal.waitingSpinnerSvg | quote }}
      - path: "/static-files/login/background.jpg"
        data: {{ .Values.theme.imagery.login.backgroundJpg | quote }}
      - path: "/robots.txt"
        data: {{ .Values.theme.other.robotsTxt | quote }}
  xwiki:
    subdomain: {{ .Values.global.hosts.xwiki | quote }}
    pathType: "ImplementationSpecific"
    paths:
      - path: "/resources/icons/xwiki/favicon.svg"
        data: {{ .Values.theme.imagery.knowledge.faviconSvg | quote }}
      - path: "/resources/icons/xwiki/favicon16.png"
        data: {{ .Values.theme.imagery.knowledge.faviconPng | quote }}
      - path: "/bin/skin/XWiki/DefaultSkin/icons.xwiki.favicon.svg"
        data: {{ .Values.theme.imagery.knowledge.faviconSvg | quote }}
      - path: "/bin/skin/XWiki/DefaultSkin/icons.xwiki.favicon16.png"
        data: {{ .Values.theme.imagery.knowledge.faviconPng | quote }}
      - path: "/robots.txt"
        data: {{ .Values.theme.other.robotsTxt | quote }}

cleanup:
  deletePodsOnSuccess: {{ .Values.debug.cleanup.deletePodsOnSuccess }}
  deletePodsOnSuccessTimeout: {{ .Values.debug.cleanup.deletePodsOnSuccessTimeout }}

containerSecurityContext:
  allowPrivilegeEscalation: false
  capabilities:
    drop:
      - "ALL"
  enabled: true
  privileged: false
  readOnlyRootFilesystem: true
  runAsNonRoot: true
  runAsGroup: 101
  runAsUser: 101
  seccompProfile:
    type: "RuntimeDefault"
  seLinuxOptions:
    {{ .Values.seLinuxOptions.opendeskStaticFiles | toYaml | nindent 4 }}

ingress:
  enabled: true
  ingressClassName: {{ .Values.ingress.ingressClassName | quote }}
  host: "{{ .Values.global.hosts.static }}.{{ .Values.global.domain }}"
  tls:
    secretName: {{ .Values.ingress.tls.secretName | quote }}
  annotations:
    {{ .Values.annotations.opendeskServicesStaticFiles.ingress | toYaml | nindent 4 }}

image:
  registry: {{ coalesce .Values.repositories.image.dockerHub .Values.global.imageRegistry .Values.images.opendeskStaticFiles.registry | quote }}
  repository: {{ .Values.images.opendeskStaticFiles.repository | quote }}
  tag: {{ .Values.images.opendeskStaticFiles.tag | quote }}
  imagePullPolicy: {{ .Values.global.imagePullPolicy | quote }}

podAnnotations:
  intents.otterize.com/service-name: "opendesk-static-files"
  {{- with .Values.annotations.opendeskServicesStaticFiles.pod }}
  {{ . | toYaml | nindent 2 }}
  {{- end }}

podSecurityContext:
  enabled: true
  fsGroup: 101
  fsGroupChangePolicy: "Always"

replicaCount: {{ .Values.replicas.opendeskStaticFiles }}

resources:
  {{ .Values.resources.opendeskStaticFiles | toYaml | nindent 2 }}

service:
  type: "ClusterIP"
  annotations:
    {{ .Values.annotations.opendeskServicesStaticFiles.service | toYaml | nindent 4 }}

serviceAccount:
  annotations:
    {{ .Values.annotations.opendeskServicesStaticFiles.serviceAccount | toYaml | nindent 4 }}

...
