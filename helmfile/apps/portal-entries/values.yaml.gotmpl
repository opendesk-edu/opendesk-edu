---
entries:
  - id: jupyterhub
    displayName:
      en: JupyterHub
      de: JupyterHub
    description:
      en: Interactive notebooks (Python, R, Julia)
      de: Interaktive Notebooks (Python, R, Julia)
    url: "https://jupyter.{{ .Values.global.domain }}"

  - id: rstudio
    displayName:
      en: RStudio
      de: RStudio
    description:
      en: R statistics environment
      de: R Statistik-Umgebung
    url: "https://r.{{ .Values.global.domain }}"

  - id: ttyd
    displayName:
      en: Web Terminal
      de: Web Terminal
    description:
      en: Browser-based Linux terminal
      de: Browser-basiertes Linux-Terminal
    url: "https://term.{{ .Values.global.domain }}"

  - id: code-server
    displayName:
      en: code-server
      de: code-server
    description:
      en: VS Code in the browser
      de: VS Code im Browser
    url: "https://code.{{ .Values.global.domain }}"

  - id: slidev
    displayName:
      en: Slidev
      de: Slidev
    description:
      en: Markdown presentations
      de: Markdown-Präsentationen
    url: "https://slides.{{ .Values.global.domain }}"

  - id: collab-dashboard
    displayName:
      en: Collab Dashboard
      de: Collab Dashboard
    description:
      en: Feature catalog for all tools
      de: Feature-Katalog für alle Tools
    url: "https://collab.{{ .Values.global.domain }}"

  - id: open-webui
    displayName:
      en: Open WebUI
      de: Open WebUI
    description:
      en: AI assistant interface
      de: KI-Assistenten-Oberfläche
    url: "https://ai.{{ .Values.global.domain }}"

  - id: drawio
    displayName:
      en: Draw.io
      de: Draw.io
    description:
      en: Diagrams and flowcharts
      de: Diagramme und Flussdiagramme
    url: "https://draw.{{ .Values.global.domain }}"

  - id: excalidraw
    displayName:
      en: Excalidraw
      de: Excalidraw
    description:
      en: Collaborative whiteboard
      de: Whiteboard für Zusammenarbeit
    url: "https://excalidraw.{{ .Values.global.domain }}"

  - id: planka
    displayName:
      en: Planka
      de: Planka
    description:
      en: Kanban project management
      de: Kanban-Projektmanagement
    url: "https://planka.{{ .Values.global.domain }}"

  - id: etherpad
    displayName:
      en: Etherpad
      de: Etherpad
    description:
      en: Collaborative text editor
      de: Kollaborativer Texteditor
    url: "https://etherpad.{{ .Values.global.domain }}"

  - id: bookstack
    displayName:
      en: BookStack
      de: BookStack
    description:
      en: Wiki and documentation
      de: Wikis und Dokumentation
    url: "https://books.{{ .Values.global.domain }}"

  - id: ssp
    displayName:
      en: Change Password
      de: Passwort ändern
    description:
      en: LDAP Self-Service Password
      de: LDAP Self-Service Password
    url: "https://ssp.{{ .Values.global.domain }}"

  - id: limesurvey
    displayName:
      en: LimeSurvey
      de: LimeSurvey
    description:
      en: Online surveys and polls
      de: Online-Umfragen und Abstimmungen
    url: "https://limesurvey.{{ .Values.global.domain }}"

  - id: typo3
    displayName:
      en: TYPO3
      de: TYPO3
    description:
      en: Enterprise content management
      de: Enterprise Content-Management
    url: "https://typo3.{{ .Values.global.domain }}"

  - id: sogo
    displayName:
      en: SOGo
      de: SOGo
    description:
      en: Groupware (Mail, Calendar, Contacts)
      de: Groupware (E-Mail, Kalender, Kontakte)
    url: "https://sogo.{{ .Values.global.domain }}"

  - id: snipr
    displayName:
      en: SNIpR
      de: SNIpR
    description:
      en: Lecture recording and transcription
      de: Vorlesungsaufzeichnung und Transkription
    url: "https://snipr.{{ .Values.global.domain }}"

  - id: zammad
    displayName:
      en: Zammad
      de: Zammad
    description:
      en: Ticketing and helpdesk system
      de: Ticketsystem und Helpdesk
    url: "https://helpdesk.{{ .Values.global.domain }}"

ldap:
  baseDn: {{ .Values.ldap.baseDn | default "dc=swp-ldap,dc=internal" | quote }}
  adminDn: {{ .Values.ldap.adminDn | default "cn=admin,dc=swp-ldap,dc=internal" | quote }}
