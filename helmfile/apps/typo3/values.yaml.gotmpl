---
commonAnnotations:
  {{ .Values.annotations.typo3.common | toYaml | nindent 2 }}

typo3:
  # Image configuration
  image: {{ .Values.images.typo3.repository | default "ghcr.io/opendesk-edu/typo3" | quote }}
  tag: {{ .Values.images.typo3.tag | default "13.4.0" | quote }}
  port: 80

  # Database configuration
  db:
    user: {{ .Values.database.typo3.name | default "typo3" | quote }}
    name: {{ .Values.database.typo3.name | default "typo3" | quote }}

  # Volume configuration
  volumes:
    fileadmin:
      size: {{ .Values.persistence.typo3.fileadmin.size | default "5Gi" | quote }}
      accessMode: "ReadWriteMany"
    var:
      size: {{ .Values.persistence.typo3.var.size | default "1Gi" | quote }}
      accessMode: "ReadWriteOnce"

  # Resource configuration
  resources:
    requests:
      cpu: {{ .Values.resources.typo3.requests.cpu | default "100m" | quote }}
      memory: {{ .Values.resources.typo3.requests.memory | default "256Mi" | quote }}
    limits:
      cpu: {{ .Values.resources.typo3.limits.cpu | default "1000m" | quote }}
      memory: {{ .Values.resources.typo3.limits.memory | default "1Gi" | quote }}

  # Replica count
  replicas: {{ default 1 .Values.replicas.typo3 }}

  # Install tool password (hashed)
  installToolPassword: {{ .Values.secrets.typo3.installToolPassword | default "changeme" | quote }}

# Ingress configuration
ingress:
  enabled: {{ .Values.ingress.enabled }}
  className: {{ .Values.ingress.ingressClassName | quote }}
  annotations:
    {{ .Values.annotations.typo3.ingress | toYaml | nindent 4 }}
    haproxy-ingress.github.io/ssl-redirect: "true"
    haproxy-ingress.github.io/proxy-body-size: "{{ .Values.ingress.parameters.bodySize.typo3 }}"
    haproxy-ingress.github.io/timeout-server: "{{ .Values.ingress.parameters.bodyTimeout.typo3 }}s"
    haproxy-ingress.github.io/timeout-client: "{{ .Values.ingress.parameters.bodyTimeout.typo3 }}s"
  hosts:
    - host: "{{ .Values.global.hosts.typo3 }}.{{ .Values.global.domain }}"
      paths:
        - path: /
          pathType: "ImplementationSpecific"
  tls:
    - secretName: "opendesk-certificates-tls"
      hosts:
        - "{{ .Values.global.hosts.typo3 }}.{{ .Values.global.domain }}"

# Embedded MariaDB configuration
mariadb:
  enabled: true
  auth:
    username: {{ .Values.database.typo3.name | default "typo3" | quote }}
    password: ""
    database: {{ .Values.database.typo3.name | default "typo3" | quote }}
  primary:
    persistence:
      enabled: true
      size: "8Gi"
      accessMode: "ReadWriteOnce"

# Service configuration
service:
  annotations:
    {{ .Values.annotations.typo3.service | toYaml | nindent 4 }}
  externalPort: 80
  enabled: true

# Service account configuration
serviceAccount:
  annotations:
    {{ .Values.annotations.typo3.serviceAccount | toYaml | nindent 4 }}

# Volume permissions
volumePermissions:
  enabled: true

# Node selector
nodeSelector: {}

# Tolerations
tolerations: []

# Affinity
affinity: {}
