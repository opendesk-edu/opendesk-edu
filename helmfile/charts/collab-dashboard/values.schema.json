{
  "$schema": "https://json-schema.org/draft-07/schema",
  "type": "object",
  "properties": {
    "replicaCount": {
      "type": "integer",
      "minimum": 1
    },
    "image": {
      "$ref": "#/definitions/imageSpec"
    },
    "service": {
      "$ref": "#/definitions/serviceSpec"
    },
    "ingress": {
      "$ref": "#/definitions/ingressSpec"
    },
    "resources": {
      "$ref": "#/definitions/resources"
    },
    "persistence": {
      "$ref": "#/definitions/persistenceSpec"
    },
    "nodeSelector": {
      "type": "object"
    },
    "tolerations": {
      "type": "array"
    },
    "affinity": {
      "type": "object"
    },
    "oauth2": {
      "$ref": "#/definitions/oauth2Spec"
    }
  },
  "definitions": {
    "imageSpec": {
      "type": "object",
      "properties": {
        "repository": {
          "type": "string"
        },
        "tag": {
          "type": "string"
        },
        "pullPolicy": {
          "type": "string",
          "enum": [
            "Always",
            "IfNotPresent",
            "Never"
          ]
        }
      }
    },
    "serviceSpec": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "ClusterIP",
            "NodePort",
            "LoadBalancer"
          ]
        },
        "port": {
          "type": "integer"
        }
      }
    },
    "ingressSpec": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "className": {
          "type": "string"
        },
        "annotations": {
          "type": "object"
        },
        "hosts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "host": {
                "type": "string"
              },
              "paths": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "path": {
                      "type": "string"
                    },
                    "pathType": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "tls": {
          "type": "array"
        }
      }
    },
    "resources": {
      "type": "object",
      "properties": {
        "requests": {
          "$ref": "#/definitions/resourceSpec"
        },
        "limits": {
          "$ref": "#/definitions/resourceSpec"
        }
      }
    },
    "resourceSpec": {
      "type": "object",
      "properties": {
        "cpu": {
          "type": "string"
        },
        "memory": {
          "type": "string"
        }
      }
    },
    "persistenceSpec": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "size": {
          "type": "string"
        },
        "accessMode": {
          "type": "string"
        }
      }
    },
    "oauth2Spec": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "provider": {
          "type": "string"
        },
        "clientId": {
          "type": "string"
        },
        "clientSecret": {
          "type": "string"
        },
        "oidcIssuerUrl": {
          "type": "string",
          "format": "uri"
        },
        "cookieSecret": {
          "type": "string"
        }
      }
    },
    "opencloudSpec": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "username": {
          "type": "string"
        },
        "password": {
          "type": "string"
        },
        "syncInterval": {
          "type": "string"
        },
        "remotePath": {
          "type": "string"
        },
        "mountPath": {
          "type": "string"
        }
      }
    }
  }
}