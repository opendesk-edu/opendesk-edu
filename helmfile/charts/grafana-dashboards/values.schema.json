{
  "$schema": "https://json-schema.org/draft-07/schema",
  "type": "object",
  "properties": {
    "opendeskDashingboards": {
      "type": "object",
      "properties": {
        "backupDashboard": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "filename": {
              "type": "string"
            }
          }
        },
        "logExplorerDashboard": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "filename": {
              "type": "string"
            }
          }
        }
      }
    },
    "monitoring": {
      "type": "object",
      "properties": {
        "enableLokiDatasource": {
          "type": "boolean"
        },
        "lokiServiceName": {
          "type": "string"
        },
        "lokiPort": {
          "type": "integer"
        }
      }
    }
  }
}