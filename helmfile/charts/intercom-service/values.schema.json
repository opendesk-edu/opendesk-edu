{
  "$schema": "https://json-schema.org/draft-07/schema",
  "type": "object",
  "properties": {
    "global": { "type": "object" },
    "image": { "$ref": "#/definitions/imageSpec" },
    "ics": { "$ref": "#/definitions/icsConfig" },
    "provisioning": { "$ref": "#/definitions/provisioningConfig" },
    "ingress": { "$ref": "#/definitions/ingressConfig" },
    "service": { "$ref": "#/definitions/serviceSpec" },
    "resources": { "$ref": "#/definitions/resourceSpec" },
    "podSecurityContext": { "type": "object" },
    "containerSecurityContext": { "type": "object" },
    "replicaCount": { "type": "integer", "minimum": 0, "default": 1 },
    "extraEnvVars": { "type": "array", "items": { "type": "object" } }
  },
  "definitions": {
    "imageSpec": {
      "type": "object",
      "properties": {
        "registry": { "type": "string" },
        "repository": { "type": "string" },
        "tag": { "type": "string" },
        "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] }
      }
    },
    "icsConfig": {
      "type": "object",
      "properties": {
        "logLevel": { "type": "string" },
        "provEndpoint": { "type": "string" },
        "helmfileAppDirectory": { "type": "string" },
        "semesterProvisioning": { "$ref": "#/definitions/semesterProvisioningConfig" }
      }
    },
    "semesterProvisioningConfig": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "image": { "$ref": "#/definitions/imageSpec" },
        "cronjob": { "type": "object" }
      }
    },
    "provisioningConfig": {
      "type": "object",
      "properties": {
        "appStore": { "$ref": "#/definitions/appStoreConfig" }
      }
    },
    "appStoreConfig": {
      "type": "object",
      "properties": {
        "url": { "type": "string", "format": "uri" },
        "token": { "type": "string" },
        "enabled": { "type": "boolean" }
      }
    },
    "ingressConfig": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "className": { "type": "string" },
        "hosts": { "type": "array", "items": { "type": "object" } }
      }
    },
    "serviceSpec": {
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["ClusterIP", "NodePort", "LoadBalancer"] },
        "port": { "type": "integer" }
      }
    },
    "resourceSpec": {
      "type": "object",
      "properties": {
        "limits": { "$ref": "#/definitions/resourceList" },
        "requests": { "$ref": "#/definitions/resourceList" }
      }
    },
    "resourceList": {
      "type": "object",
      "properties": {
        "cpu": { "type": "string", "pattern": "^[0-9]+m?$" },
        "memory": { "type": "string", "pattern": "^[0-9]+[A-Za-z]+$" }
      }
    }
  }
}
