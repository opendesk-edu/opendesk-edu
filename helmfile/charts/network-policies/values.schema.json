{
  "$schema": "https://json-schema.org/draft-07/schema",
  "type": "object",
  "properties": {
    "betty": {
      "$ref": "#/definitions/bettySpec"
    },
    "defaultDenyPolicy": {
      "$ref": "#/definitions/policyToggle"
    },
    "dnsPolicy": {
      "$ref": "#/definitions/policyToggle"
    },
    "ingressControllerPolicy": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "ingressClassNames": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "serviceToServicePolicies": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "rules": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "podSelector": {
                "type": "object"
              },
              "to": {
                "type": "array"
              },
              "ports": {
                "type": "array"
              }
            }
          }
        }
      }
    }
  },
  "definitions": {
    "bettySpec": {
      "type": "object",
      "properties": {
        "image": {
          "type": "object"
        },
        "imagePullPolicy": {
          "type": "string"
        },
        "resources": {
          "$ref": "#/definitions/resources"
        }
      }
    },
    "policyToggle": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      }
    },
    "resources": {
      "type": "object",
      "properties": {
        "limits": {
          "$ref": "#/definitions/resourceSpec"
        },
        "requests": {
          "$ref": "#/definitions/resourceSpec"
        }
      }
    },
    "resourceSpec": {
      "type": "object",
      "properties": {
        "cpu": {
          "type": "string"
        },
        "memory": {
          "type": "string"
        }
      }
    }
  }
}