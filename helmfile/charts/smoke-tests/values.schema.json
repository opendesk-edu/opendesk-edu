{
  "$schema": "https://json-schema.org/draft-07/schema",
  "type": "object",
  "properties": {
    "schedule": {
      "type": "string"
    },
    "concurrencyPolicy": {
      "type": "string"
    },
    "successfulJobsHistoryLimit": {
      "type": "integer"
    },
    "failedJobsHistoryLimit": {
      "type": "integer"
    },
    "activeDeadlineSeconds": {
      "type": "integer"
    },
    "ttlSecondsAfterFinished": {
      "type": "integer"
    },
    "image": {
      "type": "object",
      "properties": {
        "repository": {
          "type": "string"
        },
        "tag": {
          "type": "string"
        },
        "pullPolicy": {
          "type": "string"
        }
      }
    },
    "services": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "url": {
            "type": "string",
            "format": "uri"
          }
        }
      }
    },
    "extraChecks": {
      "type": "object",
      "properties": {
        "http": {
          "type": "array"
        },
        "ssl": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "oidc": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "portalEntries": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "monitoring": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "namespace": {
          "type": "string"
        },
        "releaseLabel": {
          "type": "string"
        }
      }
    },
    "resources": {
      "$ref": "#/definitions/resources"
    }
  },
  "definitions": {
    "resources": {
      "type": "object",
      "properties": {
        "requests": {
          "$ref": "#/definitions/resourceSpec"
        },
        "limits": {
          "$ref": "#/definitions/resourceSpec"
        }
      }
    },
    "resourceSpec": {
      "type": "object",
      "properties": {
        "cpu": {
          "type": "string"
        },
        "memory": {
          "type": "string"
        }
      }
    }
  }
}