{
  "$schema": "https://json-schema.org/draft-07/schema",
  "type": "object",
  "properties": {
    "ldap": {
      "type": "object",
      "properties": {
        "host": {
          "type": "string"
        },
        "port": {
          "type": "integer"
        },
        "baseDn": {
          "type": "string"
        },
        "bindDn": {
          "type": "string"
        },
        "bindPassword": {
          "type": "string"
        }
      }
    },
    "bootstrap": {
      "type": "object",
      "properties": {
        "organizations": {
          "type": "array"
        },
        "users": {
          "type": "array"
        },
        "faculties": {
          "type": "array"
        },
        "courses": {
          "type": "array"
        }
      }
    },
    "image": {
      "$ref": "#/definitions/imageSpec"
    }
  },
  "definitions": {
    "imageSpec": {
      "type": "object",
      "properties": {
        "repository": {
          "type": "string"
        },
        "tag": {
          "type": "string"
        },
        "pullPolicy": {
          "type": "string"
        }
      }
    }
  }
}