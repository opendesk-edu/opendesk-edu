{{ $root := . }}

environments:
  edu:
    values:
      - environments/edu/ce-overrides.yaml
      - environments/edu/secrets.yaml
      - environments/edu/images.yaml
  edu-test:
    values:
      - environments/edu/test/values.yaml.gotmpl

repositories:
  - name: bitnami
    url: oci://registry-1.docker.io/bitnamicharts

helmfiles:
