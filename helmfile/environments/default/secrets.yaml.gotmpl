# SPDX-License-Identifier: Apache-2.0
---
{{- $masterPassword := required "A non-empty MASTER_PASSWORD is required!" (env "MASTER_PASSWORD") }}
secrets:
  cassandra:
    rootPassword: {{ derivePassword 1 "long" $masterPassword "cassandra" "root_password" | sha1sum | quote }}
    dovecotACLUser: {{ derivePassword 1 "long" $masterPassword "cassandra" "dovecot_acl_user" | sha1sum | quote }}
    dovecotDictmapUser: {{ derivePassword 1 "long" $masterPassword "cassandra" "dovecot_dictmap_user" | sha1sum | quote }}
  oxAppSuite:
    adminPassword: {{ derivePassword 1 "long" $masterPassword "ox_appsuite" "admin_password" | sha1sum | quote }}
    basicAuthPassword: {{ derivePassword 1 "long" $masterPassword "ox_appsuite" "basic_auth_password" | sha1sum | quote }}
    cookieHashSalt: {{ derivePassword 1 "long" $masterPassword "ox_appsuite" "cookie_hash_salt" | sha1sum | quote }}
    hzGroupPassword: {{ derivePassword 1 "long" $masterPassword "ox_appsuite" "hz_group_password" | sha1sum | quote }}
    jolokiaPassword: {{ derivePassword 1 "long" $masterPassword "ox_appsuite" "jolokia_password" | sha1sum | quote }}
    migrationsMasterPassword: {{ derivePassword 1 "long" (env "MASTER_PASSWORD" | default "opendesk") "ox_appsuite" "migrations_master_password" | sha1sum | quote }}
    oxguardMC: {{ printf "MC%s" (derivePassword 1 "long" $masterPassword "ox_appsuite" "oxguardMC" | sha1sum | trunc 20 | b64enc) | quote }}
    oxguardRC: {{ printf "RC%s" (derivePassword 1 "long" $masterPassword "ox_appsuite" "oxguardRC" | sha1sum | trunc 20 | b64enc) | quote }}
    sessiondEncryptionKey: {{ derivePassword 1 "long" $masterPassword "ox_appsuite" "sessiond_encryption_key" | sha1sum | quote }}
    shareCryptKey: {{ derivePassword 1 "long" $masterPassword "ox_appsuite" "share_crypt_key" | sha1sum | quote }}
    synapseAsToken: {{ derivePassword 1 "long" $masterPassword "ox_appsuite" "as_token" | sha1sum | quote }}
  oxConnector:
    provisioningApiPassword: {{ derivePassword 1 "long" $masterPassword "nubus" "ox-connector" | sha1sum | quote }}
  postfix:
    opendeskSystemPassword: {{ derivePassword 1 "long" $masterPassword "postfix" "opendesk-system" | sha1sum | quote }}
  nubus:
    masterpassword: {{ $masterPassword | quote }}
    ldapSecret: {{ derivePassword 1 "long" $masterPassword "cn=admin" "ldap" | sha1sum | quote }}
    ldapSearch:
      keycloak: {{ derivePassword 1 "long" $masterPassword "nubus" "ldapsearch_keycloak" | sha1sum | quote }}
      nextcloud: {{ derivePassword 1 "long" $masterPassword "nubus" "ldapsearch_nextcloud" | sha1sum | quote }}
      dovecot: {{ derivePassword 1 "long" $masterPassword "nubus" "ldapsearch_dovecot" | sha1sum | quote }}
      element: {{ derivePassword 1 "long" $masterPassword "nubus" "ldapsearch_element" | sha1sum | quote }}
      ox: {{ derivePassword 1 "long" $masterPassword "nubus" "ldapsearch_ox" | sha1sum | quote }}
      postfix: {{ derivePassword 1 "long" $masterPassword "nubus" "ldapsearch_postfix" | sha1sum | quote }}
      openproject: {{ derivePassword 1 "long" $masterPassword "nubus" "ldapsearch_openproject" | sha1sum | quote }}
      xwiki: {{ derivePassword 1 "long" $masterPassword "nubus" "ldapsearch_xwiki" | sha1sum | quote }}
    systemAccounts:
      administratorPassword: {{ derivePassword 1 "long" $masterPassword "nubus" "Administrator" | sha1sum | quote }}
      sysIdpUserPassword: {{ derivePassword 1 "long" $masterPassword "nubus" "sysIdpUser" | sha1sum | quote }}
    portalConsumer:
      provisioningApiPassword: {{ derivePassword 1 "long" $masterPassword "portal-consumer" "provisioning-api" | sha1sum | quote }}
    selfserviceConsumer:
      provisioningApiPassword: {{ derivePassword 1 "long" $masterPassword "selfservice-consumer" "provisioning-api" | sha1sum | quote }}
    provisioning:
      api:
        adminPassword: {{ derivePassword 1 "long" $masterPassword "api" "admin_api" | sha1sum | quote }}
        # prefix `nats` passwords with `n` because of an upstream bug, for further information see https://gitlab.opencode.de/bmi/opendesk/deployment/opendesk/-/blob/main/docs/getting-started.md?ref_type=heads#password-seed
        natsPassword: {{ printf "n%s" (derivePassword 1 "long" $masterPassword "api" "nats" | sha1sum) | quote }}
        prefillPassword: {{ derivePassword 1 "long" $masterPassword "prefill" "prefill_service" | sha1sum | quote }}
        udmTransformerPassword: {{ derivePassword 1 "long" $masterPassword "udmproducer" "events_api" | sha1sum | quote }}
      dispatcherNatsPassword: {{ printf "n%s" (derivePassword 1 "long" $masterPassword "dispatcher" "nats" | sha1sum) | quote }}
      prefillNatsPassword: {{ printf "n%s" (derivePassword 1 "long" $masterPassword "prefill" "nats" | sha1sum) | quote }}
      udmListenerNatsPassword: {{ printf "n%s" (derivePassword 1 "long" $masterPassword "udmListener" "nats" | sha1sum) | quote }}
      udmTransformerNatsPassword: {{ printf "n%s" (derivePassword 1 "long" $masterPassword "udmTransformer" "nats" | sha1sum) | quote }}
    guardian:
      udmPassword: {{ derivePassword 1 "long" $masterPassword "cn=admin" "udm" | sha1sum | quote }}
  nats:
    natsAdminPassword: {{ printf "n%s" (derivePassword 1 "long" $masterPassword "admin" "nats" | sha1sum) | quote }}
  postgresql:
    postgresUser: {{ derivePassword 1 "long" $masterPassword "postgres" "postgres_user" | sha1sum | quote }}
    keycloakUser: {{ derivePassword 1 "long" $masterPassword "postgres" "keycloak_user" | sha1sum | quote }}
    keycloakExtensionUser: {{ derivePassword 1 "long" $masterPassword "postgres" "keycloak_extensions_user" | sha1sum | quote }}
    matrixUser: {{ derivePassword 1 "long" $masterPassword "postgres" "matrix_user" | sha1sum | quote }}
    nextcloudUser: {{ derivePassword 1 "long" $masterPassword "postgres" "nextcloud_user" | sha1sum | quote }}
    notesUser: {{ derivePassword 1 "long" $masterPassword "postgres" "notes_user" | sha1sum | quote }}
    openprojectUser: {{ derivePassword 1 "long" $masterPassword "postgres" "openproject_user" | sha1sum | quote }}
    umsAuthSessionUser: {{ derivePassword 1 "long" $masterPassword "postgres" "authsession_user" | sha1sum | quote }}
    umsNotificationsApiUser: {{ derivePassword 1 "long" $masterPassword "postgres" "notificationsapi_user" | sha1sum | quote }}
    umsGuardianManagementApiUser: {{ derivePassword 1 "long" $masterPassword "postgres" "guardianmanagementapi_user" | sha1sum | quote }}
    umsSelfserviceUser: {{ derivePassword 1 "long" $masterPassword "postgres" "selfservice_user" | sha1sum | quote }}
    xwikiUser: {{ derivePassword 1 "long" $masterPassword "postgres" "xwiki_user" | sha1sum | quote }}
  mariadb:
    rootPassword: {{ derivePassword 1 "long" $masterPassword "mariadb" "root_password" | sha1sum | quote }}
    xwikiUser: {{ derivePassword 1 "long" $masterPassword "mariadb" "xwiki_user" | sha1sum | quote }}
    openxchangeUser: {{ derivePassword 1 "long" $masterPassword "mariadb" "openxchange_user" | sha1sum | quote }}
    nextcloudUser: {{ derivePassword 1 "long" $masterPassword "mariadb" "nextcloud_user" | sha1sum | quote }}
  # In order to keep make migration from MinIO to SeaweedFS easier, MinIO credentials are reused for SeaweedFS
  # However, with the removal of MinIO in the openDesk 2.0 release, this configuration will be renamed to `objectstorage`
  minio:
    dovecotUser: {{ (derivePassword 1 "long" $masterPassword "minio" "dovecot_user" | sha1sum | quote) }}
    rootPassword: {{ (derivePassword 1 "long" $masterPassword "minio" "root_password" | sha1sum | quote) }}
    migrationsUser: {{ (derivePassword 1 "long" $masterPassword "minio" "migrations_user" | sha1sum | quote) }}
    nextcloudUser: {{ (derivePassword 1 "long" $masterPassword "minio" "nextcloud_user" | sha1sum | quote) }}
    notesUser: {{ (derivePassword 1 "long" $masterPassword "minio" "notes_user" | sha1sum | quote) }}
    openprojectUser: {{ (derivePassword 1 "long" $masterPassword "minio" "openproject_user" | sha1sum | quote) }}
    openxchangeUser: {{ (derivePassword 1 "long" $masterPassword "minio" "openxchange_user" | sha1sum | quote) }}
    umsUser: {{ (derivePassword 1 "long" $masterPassword "minio" "ums_user" | sha1sum | quote) }}
  keycloak:
    adminPassword: {{ derivePassword 1 "long" $masterPassword "keycloak" "adminPassword" | sha1sum | quote }}
    clientSecret:
      portal: {{ derivePassword 1 "long" $masterPassword "nubus" "portal_client_secret" | sha1sum | quote }}
      dovecot: {{ derivePassword 1 "long" $masterPassword "keycloak" "dovecot_client_secret" | sha1sum | quote }}
      intercom: {{ derivePassword 1 "long" $masterPassword "keycloak" "intercom_client_secret" | sha1sum | quote }}
      matrix: {{ derivePassword 1 "long" $masterPassword "keycloak" "matrix_client_secret" | sha1sum | quote }}
      jitsi: {{ derivePassword 1 "long" $masterPassword "keycloak" "jitsi_plain_client_secret" | sha1sum | quote }}
      ncoidc: {{ derivePassword 1 "long" $masterPassword "keycloak" "ncoidc_client_secret" | sha1sum | quote }}
      openproject: {{ derivePassword 1 "long" $masterPassword "keycloak" "openproject_client_secret" | sha1sum | quote }}
      xwiki: {{ derivePassword 1 "long" $masterPassword "keycloak" "xwiki_client_secret" | sha1sum | quote }}
      as8oidc: {{ derivePassword 1 "long" $masterPassword "keycloak" "as8oidc_client_secret" | sha1sum | quote }}
      guardian: {{ derivePassword 1 "long" $masterPassword "keycloak" "guardian_client_secret" | sha1sum | quote }}
      notes: {{ derivePassword 1 "long" $masterPassword "keycloak" "notes_client_secret" | sha1sum | quote }}
  nextcloud:
    adminPassword: {{ derivePassword 1 "long" $masterPassword "nextcloud" "nextcloud_admin_user" | sha1sum | quote }}
    metricsToken: {{ derivePassword 1 "long" $masterPassword "nextcloud" "metricsToken" | sha1sum | quote }}
    statusPassword: {{ derivePassword 1 "medium" $masterPassword "nextcloud" "nextcloud_status_user" | sha1sum | quote }}
  openproject:
    adminPassword: {{ derivePassword 1 "long" $masterPassword "openproject" "openproject_admin_user" | sha1sum | quote }}
    apiAdminUsername: {{ derivePassword 1 "long" $masterPassword "openproject" "openproject_api_admin_username" | sha1sum | quote }}
    apiAdminPassword: {{ derivePassword 1 "long" $masterPassword "openproject" "openproject_api_admin_password" | sha1sum | quote }}
  collabora:
    adminPassword: {{ derivePassword 1 "long" $masterPassword "collabora" "collabora_admin_user" | sha1sum | quote }}
  jitsi:
    jwtAppSecret: {{ derivePassword 1 "long" $masterPassword "jistiStandalone" "jwtAppSecret" | sha1sum | quote }}
    jibriRecorderPassword: {{ derivePassword 1 "long" $masterPassword "jistiStandalone" "jibriRecorderPassword" | sha1sum | quote }}
    jibriXmppPassword: {{ derivePassword 1 "long" $masterPassword "jistiStandalone" "jibriXmppPassword" | sha1sum | quote }}
    jicofoAuthPassword: {{ derivePassword 1 "long" $masterPassword "jistiStandalone" "jicofoAuthPassword" | sha1sum | quote }}
    jicofoComponentPassword: {{ derivePassword 1 "long" $masterPassword "jistiStandalone" "jicofoComponentPassword" | sha1sum | quote }}
    jigasiXmppPassword: {{ derivePassword 1 "long" $masterPassword "jistiStandalone" "jigasiXmppPassword" | sha1sum | quote }}
    jvbAuthPassword: {{ derivePassword 1 "long" $masterPassword "jistiStandalone" "jvbAuthPassword" | sha1sum | quote }}
  whiteboard:
    apiKey: {{ derivePassword 1 "long" $masterPassword "whiteboard" "apiKey" | sha1sum | quote }}
  centralnavigation:
    apiKey: {{ derivePassword 1 "long" $masterPassword "centralnavigation" "api_key" | sha1sum | quote }}
  redis:
    password: {{ derivePassword 1 "long" $masterPassword "redis" "password" | sha1sum | quote }}
  dovecot:
    doveadm: {{ derivePassword 1 "long" $masterPassword "dovecot" "doveadm" | sha1sum | quote }}
    sharedMailboxesMasterPassword: {{ derivePassword 1 "long" $masterPassword "dovecot" "sharedMailboxesMasterPassword" | sha1sum | quote }}
  xwiki:
    superadminpassword: {{ derivePassword 1 "long" $masterPassword "xwiki" "superadminpassword" | sha1sum | quote }}
  intercom:
    secret: {{ derivePassword 1 "long" $masterPassword "intercom" "secret" | sha1sum | quote }}
    synapseAsToken: {{ derivePassword 1 "long" $masterPassword "intercom" "as_token" | sha1sum | quote }}
  matrixAdminBot:
    backupPassphrase: {{ derivePassword 1 "long" $masterPassword "matrix-admin-bot" "backupPassphrase" | sha1sum | quote }}
    password: {{ derivePassword 1 "long" $masterPassword "matrix-admin-bot" "password" | sha1sum | quote }}
    synapseAsToken: {{ derivePassword 1 "long" $masterPassword "matrix-admin-bot" "as_token" | sha1sum | quote }}
  matrixAuditBot:
    backupPassphrase: {{ derivePassword 1 "long" $masterPassword "matrix-auditbot-bot" "backupPassphrase" | sha1sum | quote }}
    password: {{ derivePassword 1 "long" $masterPassword "matrix-auditbot-bot" "password" | sha1sum | quote }}
    synapseAsToken: {{ derivePassword 1 "long" $masterPassword "matrix-audit-bot" "as_token" | sha1sum | quote }}
  matrixGroupsync:
    synapseAsToken: {{ derivePassword 1 "long" $masterPassword "matrix-groupsync" "as_token" | sha1sum | quote }}
  matrixNeoDateFixBot:
    password: {{ derivePassword 1 "long" $masterPassword "matrix-neodatefix-bot" "password" | sha1sum | quote }}
  matrixUserVerificationService:
    password: {{ derivePassword 1 "long" $masterPassword "matrix-user-verification-service" "password" | sha1sum | quote }}
  synapse:
    registrationSharedSecret: {{ derivePassword 1 "long" $masterPassword "synapse" "registrationSharedSecret" | sha1sum | quote }}
  certificates:
    password: {{ derivePassword 1 "long" $masterPassword "certificates" "password" | sha1sum | quote }}
  notes:
    djangoSecretKey: {{ derivePassword 1 "long" $masterPassword "notes" "djangoSecretKey" | sha256sum | quote }}
    superuser: {{ derivePassword 1 "long" $masterPassword "notes" "superuser" | sha1sum | quote }}
    collaborationSecret: {{ derivePassword 1 "long" $masterPassword "notes" "collaborationSecret" | sha1sum | quote }}
...
