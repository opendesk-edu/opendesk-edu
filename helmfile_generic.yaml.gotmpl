---
# ╔═══════════════════════════════════════════════════════════╗
# ║  DEPRECATED — Consolidation in progress                  ║
# ║  All services migrating to opendesk namespace.           ║
# ║  See opendesk/helmfile_generic.yaml.gotmpl               ║
# ╚═══════════════════════════════════════════════════════════╝
#
# Services remaining here are NOT yet consolidated:
#   - Stateful services with separate data (moodle, ilias, openproject, etc.)
#   - Edu-only services pending migration (n8n, typo3, etc.)
#
# Consolidated into opendesk (removed from here):
#   - drawio, excalidraw, collab-dashboard, opendesk-static-files
#   - clamav-simple, memcached, postfix
#
# Advanced Configuration: Nested States
#
helmfiles:
  # Path to the helmfile state file being processed BEFORE releases in this state file
  - path: "helmfile/apps/opendesk-migrations-pre/helmfile-child.yaml.gotmpl"
    values: &values
      - "helmfile/environments/default/*.yaml.gotmpl"
      - {{ toYaml .Values | nindent 8 }}
      {{- if eq (env "OPENDESK_ENTERPRISE") "true" }}
      - "helmfile/environments/default-enterprise-overrides/*.yaml.gotmpl"
      {{- end }}

  ## Core openDesk services
  - path: "helmfile/apps/opendesk-services/helmfile-child.yaml.gotmpl"
    values: *values
  - path: "helmfile/apps/services-external/helmfile-child.yaml.gotmpl"
    values: *values

  ## Nubus portal & identity
  - path: "helmfile/apps/nubus/helmfile-child.yaml.gotmpl"
    values: *values

  ## Groupware & communication
  - path: "helmfile/apps/open-xchange/helmfile-child.yaml.gotmpl"
    values: *values
  - path: "helmfile/apps/sogo/helmfile-child.yaml.gotmpl"
    values: *values

  ## Storage & files
  - path: "helmfile/apps/nextcloud/helmfile-child.yaml.gotmpl"
    values: *values
  - path: "helmfile/apps/opencloud/helmfile-child.yaml.gotmpl"
    values: *values
  - path: "helmfile/apps/seaweedfs/helmfile-child.yaml.gotmpl"
    values: *values

  ## Office & collaboration
  - path: "helmfile/apps/collabora/helmfile-child.yaml.gotmpl"
    values: *values
  - path: "helmfile/apps/cryptpad/helmfile-child.yaml.gotmpl"
    values: *values
  - path: "helmfile/apps/jitsi/helmfile-child.yaml.gotmpl"
    values: *values
  - path: "helmfile/apps/element/helmfile-child.yaml.gotmpl"
    values: *values
  - path: "helmfile/apps/notes/helmfile-child.yaml.gotmpl"
    values: *values
  - path: "helmfile/apps/xwiki/helmfile-child.yaml.gotmpl"
    values: *values

  ## Documented & knowledge
  - path: "helmfile/apps/bookstack/helmfile-child.yaml.gotmpl"
    values: *values
  # drawio — consolidated to opendesk
  # excalidraw — consolidated to opendesk
  - path: "helmfile/apps/typo3/helmfile-child.yaml.gotmpl"
    values: *values

  ## Project management & helpdesk
  - path: "helmfile/apps/openproject/helmfile-child.yaml.gotmpl"
    values: *values
  - path: "helmfile/apps/planka/helmfile-child.yaml.gotmpl"
    values: *values
  - path: "helmfile/apps/zammad/helmfile-child.yaml.gotmpl"
    values: *values

  ## Learning & research tools
  - path: "helmfile/apps/moodle/helmfile-child.yaml.gotmpl"
    values: *values
  - path: "helmfile/apps/ilias/helmfile-child.yaml.gotmpl"
    values: *values
  - path: "helmfile/apps/limesurvey/helmfile-child.yaml.gotmpl"
    values: *values

  ## Scientific computing
  - path: "helmfile/apps/jupyterhub/helmfile-child.yaml.gotmpl"
    values: *values
  - path: "helmfile/apps/rstudio/helmfile-child.yaml.gotmpl"
    values: *values
  - path: "helmfile/apps/code-server/helmfile-child.yaml.gotmpl"
    values: *values
  - path: "helmfile/apps/dask/helmfile-child.yaml.gotmpl"
    values: *values

  ## AI & LLM tools
  - path: "helmfile/apps/ollama/helmfile-child.yaml.gotmpl"
    values: *values
  - path: "helmfile/apps/open-webui/helmfile-child.yaml.gotmpl"
    values: *values

  ## Real-time communication & low-code
  - path: "helmfile/apps/etherpad/helmfile-child.yaml.gotmpl"
    values: *values
  - path: "helmfile/apps/n8n/helmfile-child.yaml.gotmpl"
    values: *values

  ## Web terminals & presentation
  - path: "helmfile/apps/ttyd/helmfile-child.yaml.gotmpl"
    values: *values
  - path: "helmfile/apps/slidev/helmfile-child.yaml.gotmpl"
    values: *values

  ## Dashboard, self-service & integrations
  - path: "helmfile/apps/collab-dashboard/helmfile-child.yaml.gotmpl"
    values: *values
  - path: "helmfile/apps/self-service-password/helmfile-child.yaml.gotmpl"
    values: *values
  - path: "helmfile/apps/portal-entries/helmfile-child.yaml.gotmpl"
    values: *values
  - path: "helmfile/apps/opendesk-openproject-bootstrap/helmfile-child.yaml.gotmpl"
    values: *values
  - path: "helmfile/apps/opendesk-migrations-post/helmfile-child.yaml.gotmpl"
    values: *values

missingFileHandler: "Error"
...
