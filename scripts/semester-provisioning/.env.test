# Test environment variables for semester-provisioning API.
# Copy to .env for local development.

API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true

# ILIAS
ILIAS_API_URL=http://ilias.test/api
ILIAS_API_USER=testuser
ILIAS_API_KEY=test-key

# Moodle
MOODLE_API_URL=http://moodle.test/webservice
MOODLE_API_TOKEN=test-token

# Keycloak
KEYCLOAK_URL=http://keycloak.test:8080
KEYCLOAK_REALM=opendesk-edu
KEYCLOAK_ADMIN_USER=kcadmin
KEYCLOAK_ADMIN_PASSWORD=test-password
KEYCLOAK_CLIENT_ID=admin-cli

# HISinOne
HISINONE_WEBHOOK_SECRET=test-webhook-secret
HISINONE_WEBHOOK_PORT=8001
